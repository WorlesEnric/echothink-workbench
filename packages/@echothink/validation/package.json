{
  "name": "@echothink/validation",
  "version": "0.1.0",
  "description": "Deterministic validation pipeline and gate runners (manifest, typescript, build, permission simulation, security/import scan, dependency allowlist, effects, storybook/a11y/visual, release completeness) plus the validate:domain CLI.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "echothink-validate": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@echothink/app-domain-runtime": "file:../app-domain-runtime",
    "@echothink/app-domain-sdk": "file:../app-domain-sdk",
    "@echothink/domain-manifest": "file:../domain-manifest",
    "@echothink/shared-types": "file:../shared-types",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "vitest": "^3.1.1"
  }
}
