{
  "name": "@echothink/domain-manifest",
  "version": "0.1.0",
  "description": "App-Domain Manifest schema, parser, semantic validators, compiler, and TypeScript kernel code generator for Echothink-Workbench.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@echothink/shared-types": "file:../shared-types",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
